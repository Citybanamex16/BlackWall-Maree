<%- include('../partials/header_cliente', { pageTitle: 'Menu - Maree' }) %>

<!-- ═══════════════════════════════════════
     STICKY SUPERIOR — Cuenta + Royalty
     TODO: poblar con datos de sesión
════════════════════════════════════════ -->
<div id="sticky-top" class="sticky-top-app">
    <% if (!datosCliente) { %>
        <button type="button" class="user-profile" onclick="location.href='/';" aria-label="Logo Marée">
            <div class="logo-area">
                <span class="logo-text">MARÉE</span>
                <span class="logo-sub">LOVE AT FIRST CRÊPE</span>
            </div>
        </button>
        <button type="button" class="royalty-badge" onclick="location.href='/cliente/login';" aria-label="Ver Royalty">
            <i class="fas fa-crown"></i>
            <span>Iniciar Sesión</span>
        </button>
    <% } else { %>
        <div class="user-profile">
            <div class="logo-area">
                <span class="logo-text">MARÉE</span>
                <span class="logo-sub">Bienvenido, <%= datosCliente.nombre %></span>
            </div>
        </div>
        <div class="royalty-actions">
            <button type="button" class="btn-royalty-active" onclick="location.href='/royalty/royaltyUser'">
                <i class="fas fa-crown"></i> Rewards
            </button>
            <button type="button" class="btn-logout" onclick="localStorage.removeItem('pedido'); location.href='/cliente/logout';" aria-label="Cerrar Sesión">
                Logout
            </button>
        </div>
    <% } %>
</div>


<!-- ═══════════════════════════════════════
     STICKY INTERMEDIO — Categorías
     Movido desde .menu-column interior.
     Scroll horizontal gestionado por menu.js
════════════════════════════════════════ -->
<div id="sticky-nav-wrapper" class="sticky-nav-container">
    <div class="tabs is-toggle is-toggle-rounded " id="tabs-categorias">
        <ul id="lista-tabs">
            </ul>
    </div>
</div>

<!-- ═══════════════════════════════════════
     CONTENIDO PRINCIPAL — Tarjetas
     El JS inyecta aquí igual que antes.
     Sin section/container-fluid/menu-layout.
════════════════════════════════════════ -->
<main id="menu-root">
    <div id="menu-categorias">
        <div class="has-text-centered py-6">
            <p class="is-size-5 has-text-grey">Explorando el menú de Marée...</p>
            <progress class="progress is-small is-primary mt-4" max="100">15%</progress>
        </div>
    </div>
</main>

<!-- ═══════════════════════════════════════
     STICKY INFERIOR — Búsqueda + Promo + Eventos
     TODO: poblar con buscador y accesos rápidos
════════════════════════════════════════ -->
<div id="sticky-bottom" class="sticky-bottom-app">

    <a href="/menu/sucursales" class="btn btn-icon search-side-btn" aria-label="Mapa">
        <i class="fas fa-map-marker-alt is-size-4"></i>
    </a>

    <a href="/cliente/promosCliente" class="btn btn-icon search-side-btn" aria-label="Promos">
        <i class="fas fa-tag is-size-4"></i>
    </a>

    <button id="btn-search-toggle" class="btn btn-icon" aria-label="Buscar">
        <i class="fas fa-search is-size-4"></i>
    </button>

    <div class="search-bar-wrapper control has-icons-left" id="search-expanded" style="display:none;flex:1;">
        <input id="search-input" class="input is-rounded" type="text" placeholder="Buscar...">
        <span class="icon is-left">
            <i class="fas fa-search"></i>
        </span>
    </div>

    <a href="/cliente/eventosCliente" class="btn btn-icon search-side-btn" aria-label="Eventos">
        <i class="fas fa-calendar-alt is-size-4"></i>
    </a>

    <a href="/menu/orden" class="btn btn-icon search-side-btn" aria-label="Carrito">
        <span style="position:relative;display:inline-flex;">
            <i class="fas fa-shopping-cart is-size-4"></i>
            <span class="fab-badge">0</span>
        </span>
    </a>
</div>

<!-- FAB — Crepa Personalizada (Abajo Izquierda) -->
<!-- Mantiene los 85px que ya tienes en tu CSS -->
<button id="fab-personalizado" class="fab-app-der" aria-label="Armar tu Crepa">
    <i class="fas fa-utensils" style="font-size:20px;color:#fff;"></i>
</button>



<!-- ═══════════════════════════════════════
     MODAL — Detalle de producto
════════════════════════════════════════ -->
<dialog id="modal-overlay" class="modal-overlay">
    <div id="modal-box" class="modal-box">
        <button id="modal-close" class="modal-close-btn">✕</button>
        <div id="modal-content">
            <!-- Contenido inyectado dinámicamente por menu.js -->
        </div>
    </div>
</dialog>


<!-- ═══════════════════════════════════════
     MODAL — Error de carga del menú
════════════════════════════════════════ -->
<dialog id="menuErrorModal">
    <div class="modal-accent-bar" style="background:#e74c3c;"></div>
    <h2 style="color:#c0392b;">Error al cargar el menú</h2>
    <p>No pudimos conectar con el servidor. Por favor recarga la página o inténtalo más tarde.</p>
    <div style="display:flex; gap:10px; justify-content:flex-end; margin-top:16px;">
        <button onclick="window.location.reload()" class="button is-primary">
            Reintentar
        </button>
    </div>
</dialog>



<!-- ═══════════════════════════════════════
     Seccion — Modal Producto personalizado
════════════════════════════════════════ -->





<!-- Dialogo de error -->
<dialog id="ErrorModal" class=" mymodal">
    <h2 id="ErrorTitle">Titulo Dinámico</h2>
    <div class="modal-accent-bar"></div>
    <p id="ErrorMessage">Mensaje Dinámico</p>
    <!-- Botón con ID para manipularlo desde JS -->
    <button id="closeInvalidData" class="modal-close-btn" >Cerrar</button>
</dialog>




<script>
    const urlParams = new URLSearchParams(window.location.search);
    if (urlParams.get('authError') === 'database') {
        alert("Lo sentimos, la base de datos no pudo guardar tus datos de registro. Por favor, inténtalo más tarde.");
        window.history.replaceState({}, document.title, window.location.pathname);
    }
</script>
<script src="/js/menudigital/menu.js"></script>
<script src="/js/menudigital/menuProductoPersonalizado.js"></script>
</body>
</html>