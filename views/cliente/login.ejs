<!DOCTYPE html>
<html>
<head>
	<meta charset="utf-8">
	<meta name="viewport" content="width=device-width, initial-scale=1">
	<link rel="stylesheet" href="/css/bulma.min.css">
	<title></title>
</head>
<body>

<%- include('../partials/breadcrumbs') %>



	<div class="box ">
		<h1> Iniciar Sesión</h1>
	</div>

<form action="/cliente/login" method="POST">

<!-- inicio de setting control -->
<div class="columns is-centered">
	<div class="column is-4">
		<section class="box">
			<!-- Fin de setting control -->
			 <!-- Bloques campo para Name, Gender, etc. -->
			  <div class="field">
			    <label class="label">Numero Telefónico</label>
			    <div class="control">
			      <input class="input is-info" type="tel" placeholder="Phone Number"
			      name="telefono" required />
			    </div>
			  </div>
			 

			   <div class="field">
			    <label class="label">Nombre de Usuario</label>
			    <div class="control">
			      <input class="input is-info" type="text" placeholder="Name & last name" name="nombre" required />
			    </div>
			  </div>

			   <div class="field">
			    <label class="label">Gender</label>
			    <div class="control">
			      <input class="input is-info" type="text" placeholder="Gender" 
			      name="genero" />
			    </div>
			  </div>

			  <div class="field">
			    <label class="label">Birthday</label>
			    <div class="control">
			      <input class="input is-info" type="date" placeholder="¡Birthday!" 
			      name="birthday"/>
			    </div>
			  </div>


			  <div class="field">
			    <label class="label">Mail</label>
			    <div class="control">
			      <input class="input is-info" type="email" placeholder="@mail"
			      name="mail" />
			    </div>
			  </div>

			  
			  	<button class="button is-primary is-fullwidth">Enviar</button>
			  
			  

		</section>
	</div>
</div>

</form>


	

</body>
</html>