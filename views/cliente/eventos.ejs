<%- include('../partials/header_cliente', { pageTitle: 'Eventos - Maree' }) %>
<link rel="stylesheet" href="/css/moduloMenuCSS/eventosCliente.css">
<%
const listaEventos = Array.isArray(eventos) ? eventos : []
const eventoPrincipal = listaEventos[0] || null
const restoEventos = eventoPrincipal ? listaEventos.slice(1) : []
const formatearFecha = (fecha) => {
  if (!fecha) return 'Sin fecha'
  const [anio, mes, dia] = String(fecha).split('T')[0].split('-')
  return `${dia}/${mes}/${anio}`
}
const formatearRango = (inicio, fin) => !fin || inicio === fin ? formatearFecha(inicio) : `${formatearFecha(inicio)} - ${formatearFecha(fin)}`
const claseEstado = (evento) => evento.estatus === 'live' ? 'is-live' : 'is-soon'
const textoEstado = (evento) => evento.estatus === 'live' ? 'Activo ahora' : 'Muy pronto'
%>
<body class="eventos-cliente-page">
  <div id="sticky-top" class="sticky-top-app">
    <div class="user-profile" style="cursor: pointer;" onclick="location.href='/';">
      <div class="logo-area">
        <span class="logo-text">MAREE</span>
        <span class="logo-sub">Eventos activos</span>
      </div>
    </div>
  </div>
  
  <section class="events-sticky-nav" style="position:fixed;top:60px;left:0;width:100%;z-index:95;">
    <div class="events-nav-shell">
      <span class="events-page-kicker"><i class="fas fa-calendar-alt"></i> agenda Maree</span>
      <h1 class="events-page-title">Eventos</h1>
      <div class="events-summary-pills">
        <span class="events-summary-pill"><i class="fas fa-star"></i> <%= listaEventos.length %> <%= listaEventos.length === 1 ? 'evento activo' : 'eventos activos' %></span>
        <span class="events-summary-pill is-soft"><i class="fas fa-eye"></i> Solo visualizacion</span>
      </div>
    </div>
  </section>

  <main class="events-main">
    <% if (errorCarga) { %><section class="events-callout"><span class="events-label"><i class="fas fa-circle-exclamation"></i> carga</span><p class="events-copy"><%= errorCarga %></p></section><% } %>

    <% if (eventoPrincipal) { %>
      <article class="events-highlight">
        <div class="events-hero-media"><span class="events-status-pill <%= claseEstado(eventoPrincipal) %>"><%= textoEstado(eventoPrincipal) %></span><% if (eventoPrincipal.Imagen) { %><img src="<%= eventoPrincipal.Imagen %>" alt="Imagen del evento <%= eventoPrincipal.Nombre %>"><% } else { %><div class="events-image-placeholder"><div><i class="fas fa-calendar-days"></i><span>Evento Maree</span></div></div><% } %><div class="events-hero-overlay"></div></div>
        <div class="events-hero-body">
          <span class="events-label"><i class="fas fa-star"></i> destacado</span>
          <h2 class="events-title"><%= eventoPrincipal.Nombre %></h2>
          <p class="events-copy"><%= eventoPrincipal.Descripcion || 'Descubre la experiencia especial que Maree tiene activa para ti.' %></p>
          <div class="events-chip-row">
            <span class="events-chip"><i class="fas fa-calendar-days"></i> <%= formatearRango(eventoPrincipal.Fecha_Inicio, eventoPrincipal.Fecha_Final) %></span>
            <span class="events-chip secondary"><i class="fas fa-tags"></i> <%= eventoPrincipal.TotalPromociones %> promos</span>
            <span class="events-chip secondary"><i class="fas fa-utensils"></i> <%= eventoPrincipal.TotalProductos %> productos</span>
          </div>
        </div>
      </article>
    <% } %>

    <% if (restoEventos.length > 0) { %>
      <section class="events-list">
        <div class="events-section-head"><h2 class="events-section-title">Mas eventos activos</h2><span class="events-counter"><%= restoEventos.length %></span></div>
        <% restoEventos.forEach(evento => { %>
          <article class="events-card">
            <div class="events-card-thumb"><span class="events-mini-pill <%= claseEstado(evento) %>"><%= textoEstado(evento) %></span><% if (evento.Imagen) { %><img src="<%= evento.Imagen %>" alt="Imagen del evento <%= evento.Nombre %>"><% } else { %><div class="events-card-placeholder"><i class="fas fa-calendar-day"></i></div><% } %></div>
            <div class="events-card-body"><h3 class="events-card-title"><%= evento.Nombre %></h3><p class="events-card-copy"><%= evento.Descripcion || 'Evento activo disponible para consulta.' %></p><div class="events-chip-row compact"><span class="events-chip"><i class="fas fa-calendar-days"></i> <%= formatearRango(evento.Fecha_Inicio, evento.Fecha_Final) %></span><span class="events-chip secondary"><i class="fas fa-tags"></i> <%= evento.TotalPromociones %></span><span class="events-chip secondary"><i class="fas fa-utensils"></i> <%= evento.TotalProductos %></span></div></div>
          </article>
        <% }) %>
      </section>
    <% } %>

    <% if (!listaEventos.length) { %>
      <section class="events-empty"><div class="events-empty-icon"><i class="fas fa-calendar-xmark"></i></div><h2 class="events-section-title">No hay eventos activos</h2><p class="events-copy">Cuando exista un evento vigente y marcado como activo, aparecera aqui para consulta del cliente.</p></section>
    <% } %>


    <div id="sticky-bottom" class="sticky-bottom-app">

    <a href="/menu/sucursales" class="btn btn-icon search-side-btn" aria-label="Mapa">
        <i class="fas fa-map-marker-alt is-size-4"></i>
    </a>

    <% if (datosCliente) { %>
    <a href="/royalty/royaltyUser" class="btn btn-icon search-side-btn btn-rewards-glow" aria-label="Rewards">
        <i class="fas fa-crown is-size-4"></i>
    </a>
    <% } %>

    <a href="/" class="btn btn-icon search-side-btn" aria-label="Inicio">
        <i class="fas fa-house is-size-4"></i>
    </a>

    <button id="btn-search-toggle" class="btn btn-icon" aria-label="Buscar">
        <i class="fas fa-search is-size-4"></i>
    </button>

    <div class="search-bar-wrapper control has-icons-left" id="search-expanded" style="display:none;flex:1;">
        <input id="search-input" class="input is-rounded" type="text" placeholder="Buscar...">
        <span class="icon is-left">
            <i class="fas fa-search"></i>
        </span>
    </div>

    <a href="/menu/orden" class="btn btn-icon search-side-btn" aria-label="Carrito">
        <span style="position:relative;display:inline-flex;">
            <i class="fas fa-shopping-cart is-size-4"></i>
            <span class="fab-badge">0</span>
        </span>
    </a>

</div>

  </main>




</body>
</html>
