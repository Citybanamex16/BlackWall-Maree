<%- include('../partials/header_cliente', { pageTitle: 'Mi perfil - Marée' }) %>

<body>
<main class="page-wrap">
  <header style="margin-bottom: 32px;">
    <h1 class="page-title">Mi perfil</h1>
    <p style="color: var(--c-text-muted); font-size: 16px; margin-top: 8px;">
      Modifica tus datos personales
    </p>
  </header>

  <% if (error) { %>
    <div class="notification status-pill is-danger" style="border-radius: var(--radius-md); padding: 16px; width: 100%; margin-bottom: 24px;">
      <%= error %>
    </div>
  <% } %>

  <% if (success) { %>
    <div class="notification status-pill is-active" style="border-radius: var(--radius-md); padding: 16px; width: 100%; margin-bottom: 24px;">
      <%= success %>
    </div>
  <% } %>

  <% if (cliente) { %>
    <div class="card-base" style="max-width: 720px;">
      <form action="/cliente/perfil" method="POST">
        <div style="display: flex; flex-direction: column; gap: 18px; margin-bottom: 28px;">

          <div>
            <label style="color: var(--c-text-muted); text-transform: uppercase; font-size: 11px; letter-spacing: 1px;">
              Número telefónico
            </label>
            <input
              class="input"
              style="margin-top: 6px;"
              type="text"
              value="<%= cliente.numero_telefonico %>"
              disabled>
          </div>

          <div>
            <label style="color: var(--c-text-muted); text-transform: uppercase; font-size: 11px; letter-spacing: 1px;">
              Nombre
            </label>
            <input
              class="input"
              style="margin-top: 6px;"
              type="text"
              name="nombre"
              value="<%= cliente.nombre || '' %>"
              required>
          </div>

          <div>
            <label style="color: var(--c-text-muted); text-transform: uppercase; font-size: 11px; letter-spacing: 1px;">
              Correo
            </label>
            <input
              class="input"
              style="margin-top: 6px;"
              type="email"
              name="correo"
              value="<%= cliente.correo || '' %>"
              required>
          </div>

          <div>
            <label style="color: var(--c-text-muted); text-transform: uppercase; font-size: 11px; letter-spacing: 1px;">
              Género
            </label>
            <div class="select is-fullwidth" style="margin-top: 6px;">
              <select name="genero" required>
                <option value="">Selecciona una opción</option>
                <option value="Femenino" <%= cliente.genero === 'Femenino' ? 'selected' : '' %>>Femenino</option>
                <option value="Masculino" <%= cliente.genero === 'Masculino' ? 'selected' : '' %>>Masculino</option>
                <option value="Otro" <%= cliente.genero === 'Otro' ? 'selected' : '' %>>Otro</option>
                <option value="Prefiero no decirlo" <%= cliente.genero === 'Prefiero no decirlo' ? 'selected' : '' %>>Prefiero no decirlo</option>
              </select>
            </div>
          </div>

          <div>
            <label style="color: var(--c-text-muted); text-transform: uppercase; font-size: 11px; letter-spacing: 1px;">
              Fecha de nacimiento
            </label>
            <input
              class="input"
              style="margin-top: 6px;"
              type="date"
              name="fecha_nacimiento"
              value="<%= cliente.fecha_nacimiento ? String(cliente.fecha_nacimiento).slice(0, 10) : '' %>"
              required>
          </div>
        </div>

        <div style="display: flex; gap: 12px; border-top: 1px solid var(--c-border); padding-top: 24px;">
          <button class="btn-danger" type="submit">
            Guardar cambios
          </button>
          <a href="/cliente/menu" class="btn-ghost">
            Volver al menú
          </a>
        </div>
      </form>
    </div>
  <% } %>
</main>

</body>
</html>