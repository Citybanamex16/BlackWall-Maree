<%- include('../partials/header_cliente', { pageTitle: 'Mapa - Marée' }) %>

<body>
  <div class="mapa-page">
    <header class="mapa-header">
      <a href="/menu/menu" class="mapa-back">
        <i class="fa-solid fa-arrow-left"></i>
        Volver al menú
      </a>

      <h1>Mapa Interactivo</h1>
      <p>Selecciona una sucursal para verla en el mapa</p>
    </header>

    <main class="mapa-main">
      <section class="mapa-layout">
        <div class="mapa-columna">
          <div id="contenedor-mapa"></div>

          <div class="mapa-acciones">
            <button id="btnMiUbicacion" class="button is-light" type="button">
              <i class="fa-solid fa-location-crosshairs"></i>
              Usar mi ubicación
            </button>

            <a id="btnAbrirMapa" class="button is-dark" target="_blank" rel="noopener">
              <i class="fa-solid fa-map-location-dot"></i>
              Abrir ruta
            </a>
          </div>

          <p id="mapaMensaje" class="mapa-mensaje"></p>
        </div>

        <aside class="direccion-columna">
          <div id="contenedor-sucursales"></div>
        </aside>
      </section>
    </main>
  </div>

  <div id="sticky-bottom" class="sticky-bottom-app">

    <a href="/cliente/eventosCliente" class="btn btn-icon search-side-btn" aria-label="Eventos">
        <i class="fas fa-calendar-alt is-size-4"></i>
    </a>

    <% if (datosCliente) { %>
    <a href="/royalty/royaltyUser" class="btn btn-icon search-side-btn btn-rewards-glow" aria-label="Rewards">
        <i class="fas fa-crown is-size-4"></i>
    </a>
    <% } %>

    <a href="/" class="btn btn-icon search-side-btn" aria-label="Inicio">
        <i class="fas fa-house is-size-4"></i>
    </a>

    <button id="btn-search-toggle" class="btn btn-icon" aria-label="Buscar">
        <i class="fas fa-search is-size-4"></i>
    </button>

    <div class="search-bar-wrapper control has-icons-left" id="search-expanded" style="display:none;flex:1;">
        <input id="search-input" class="input is-rounded" type="text" placeholder="Buscar...">
        <span class="icon is-left">
            <i class="fas fa-search"></i>
        </span>
    </div>

    <a href="/menu/orden" class="btn btn-icon search-side-btn" aria-label="Carrito">
        <span style="position:relative;display:inline-flex;">
            <i class="fas fa-shopping-cart is-size-4"></i>
            <span class="fab-badge">0</span>
        </span>
    </a>

  </div>

  <script src="/js/menudigital/mapaScript.js"></script>
</body>
</html>