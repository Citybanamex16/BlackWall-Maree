<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Order - Marée</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bulma@1.0.4/css/bulma.min.css">
    <link rel="stylesheet" href="/css/moduloMenuCSS/menustyle.css">
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400&family=Jost:wght@300;400;500&display=swap" rel="stylesheet">
</head>
<body>
    <nav class="navbar" role="navigation" style="padding:12px 24px;border-bottom:1px solid #eee;display:flex;align-items:center;justify-content:space-between;">
        <div style="display:flex;align-items:center;gap:32px;">
            <a href="/menu/menu" style="display:flex;align-items:center;gap:6px;color:#555;font-size:14px;text-decoration:none;font-family:'Jost',sans-serif;">
                <span style="font-size:18px;">←</span>
                <span>Menú</span>
            </a>
            <div class="logo-area">
                <span class="logo-text">MARÉE</span>
                <span class="logo-sub">Love at First Crêpe</span>
            </div>
        </div>
        <div style="display:flex;align-items:center;gap:16px;">
        <a href="/cliente/login"
            style="padding:8px 18px;border:1px solid #b5956a;border-radius:6px;
                    color:#b5956a;font-size:13px;text-decoration:none;font-family:'Jost',sans-serif;">
            Iniciar Sesión
        </a>
        <span id="nav-item-count" style="font-size:13px;color:#888;font-family:'Jost',sans-serif;"></span>
        </div>
    </nav>
    
    <section class="section">
        <div class="container">

            <h1 class="page-title">Resumen de Pedido</h1>
            <p class="page-subtitle">Revisa tu orden antes de confirmar</p>

            <!-- Lista de items -->
            <div id="lista-pedido"></div>

            <!-- Mensaje si está vacío -->
            <div id="pedido-vacio" style="display:none;margin-top:32px;text-align:center;">
                <p style="color:#aaa;font-size:15px;margin-bottom:12px;">
                    No hay artículos en tu pedido.
                </p>
                <a href="/" style="color:#b5956a;font-size:14px;">← Regresar al menú</a>
            </div>

            <!-- Botón checkout -->
            <div id="seccion-checkout" style="display:none;margin-top:24px;">
                <button id="btn-checkout"
                    style="padding:14px 32px;background:#b5956a;color:#fff;
                           border:none;border-radius:6px;font-size:15px;
                           cursor:pointer;font-family:'Jost',sans-serif;">
                    Confirmar Pedido →
                </button>
            </div>

        </div>
    </section>

    <script src="/js/menudigital/order.js"></script>
</body>
</html>