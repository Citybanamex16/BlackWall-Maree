<%- include('../partials/header_cliente', { pageTitle: 'Menu - Maree' }) %>
    <link rel="stylesheet" href="/css/moduloRoyaltyCSS/royalty-cliente.css">
<body>
<%- include('../partials/breadcrumbs') %>
    
<main class="container-fluid container-md my-3 my-md-5 royalty-dashboard">
    
    <div class="row mb-4">
        <div class="col-12 col-md-8 mx-auto px-2 px-md-3">
            <div class="premium-card text-center p-4">
                
                <h1 class="fs-2 fw-bold mb-1 text-truncate">¡Hola, <%= cliente.Nombre %>!</h1>
                <p class="text-muted small mb-4">Maree Royalty</p>

                <div class="qr-container mb-4">
                    <div class="qr-placeholder mx-auto">
                        <% if (typeof qrCode !== 'undefined' && qrCode) { %>
                            <img src="<%= qrCode %>" alt="Código QR de <%= cliente.Nombre %>" class="img-fluid rounded shadow-sm">
                        <% } else { %>
                            <i class="bi bi-qr-code-scan text-danger"></i>
                            <span class="mt-2 small text-danger">Error al cargar QR</span>
                        <% } %>
                    </div>
                    <p class="text-muted mt-3 mb-0"><small><i class="bi bi-info-circle"></i> Muestra este código en caja</small></p>
                </div>

                <div class="royalty-stats row g-0">
                    <div class="stat-item col-6 border-end">
                        <span class="stat-label">Nivel</span>
                        <strong id="cliente-nivel-badge" class="badge-nivel mx-auto mt-1"><%= cliente.nivel %></strong>
                    </div>
                    <div class="stat-item col-6">
                        <span class="stat-label">Visitas</span>
                        <strong class="stat-value mt-1"><%= cliente.visitas %></strong>
                    </div>
                </div>
                
            </div>
        </div>
    </div>

    <section class="mb-4 ps-2 ps-md-0">
        <h2 class="section-title mb-3 fs-4">Tus Promociones</h2>
        <div class="scroll-horizontal pb-3" id="contenedor-promociones">
            <div class="w-100 text-center py-4 loading-state">
                <div class="spinner-border text-gold spinner-border-sm" role="status"></div> 
                <span class="ms-2 small">Cargando promociones...</span>
            </div>
        </div>
    </section>

    <section class="mb-4 ps-2 ps-md-0">
        <h2 class="section-title mb-3 fs-4">Tus Eventos</h2>
        <div class="scroll-horizontal pb-3" id="contenedor-eventos">
            <div class="w-100 text-center py-4 loading-state">
                <div class="spinner-border text-gold spinner-border-sm" role="status"></div> 
                <span class="ms-2 small">Cargando eventos...</span>
            </div>
        </div>
    </section>

    <section id="contenedor-metricas" class="container-fluid px-2 px-md-0 mb-4">
    <div class="w-100 text-center py-4">
        <div class="spinner-border text-gold spinner-border-sm" role="status"></div>
        <span class="ms-2 small text-muted">Calculando tus estadísticas...</span>
    </div>
    </section>

</main>

<a id="btn-wallet" href="#" target="_blank">
  <img src="https://help.ipswichtheatres.co.uk/hc/article_attachments/24188305565329" 
       alt="Agregar a Google Wallet" style="height: 48px;">
</a>

<script>
  fetch('/royalty/royaltyUser/api/datos')
    .then(r => r.json())
    .then(data => {
        console.log('Respuesta API:', data)
        if (data.walletLink) {
            document.getElementById('btn-wallet').href = data.walletLink
      }
    })
</script>


<script src="/js/Royalty/royalty.cliente.js"></script>
</body>
</html>