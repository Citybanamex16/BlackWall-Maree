<%- include('../partials/header_cliente', { pageTitle: 'Menu - Maree' }) %>
    <link rel="stylesheet" href="/css/moduloRoyaltyCSS/royalty-cliente.css">
<body>
<%- include('../partials/breadcrumbs') %>
    
<main class="container-fluid container-md my-3 my-md-5 royalty-dashboard">
    
    <div class="row mb-4">
        <div class="col-12 col-md-8 mx-auto px-2 px-md-3">
            <div class="premium-card text-center p-4">
        <div class="premium-card p-4">
    
            <div class="greeting-section mb-4 text-start">
                <h1 class="greeting-title text-truncate">¡Hola, <%= cliente.Nombre %>!</h1>
                <p class="loyalty-subtitle">Maree Royalty</p>
            </div>

            <div class="qr-showcase-container mb-4 mx-auto text-center">
                <div class="qr-placeholder">
                    <% if (typeof qrCode !== 'undefined' && qrCode) { %>
                        <div class="qr-image-wrapper">
                            <img src="<%= qrCode %>" alt="Código QR de <%= cliente.Nombre %>" class="img-fluid">
                        </div>
                    <% } else { %>
                        <div class="qr-error-state">
                            <i class="bi bi-qr-code-scan fs-3"></i>
                            <span class="mt-2 small">Código no disponible</span>
                        </div>
                    <% } %>
                </div>
                <div class="qr-instruction mt-3">
                    <span class="badge-instruction">
                        Muestra este código en caja
                    </span>
                </div>
            </div>
            
            <div class="sellos-section px-2 mt-4 text-start">
                <p class="sellos-title">Tus Sellos</p>
                <div id="contenedor-sellos" data-visitas="<%= cliente.visitas %>"></div>
            </div>
            <div class="text-center mt-4">
                <strong id="cliente-nivel-badge" class="badge-nivel mx-auto mt-1"><%= cliente.nivel %></strong>
            </div>
        </div>
    </div>
    
