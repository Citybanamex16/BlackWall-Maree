<%- include('../partials/header_cliente', { pageTitle: 'Menu - Maree' }) %>
    <link rel="stylesheet" href="/css_new/royalty-cliente.css">
<body>
<%- include('../partials/breadcrumbs') %>
    
<main class="container-fluid container-md my-3 my-md-5 royalty-dashboard">
    
    <div class="row mb-4">
        <div class="col-12 col-md-8 mx-auto px-2 px-md-3">
            <div class="premium-card text-center p-4">
                
                <h1 class="fs-2 fw-bold mb-1 text-truncate">¡Hola, <%= cliente.Nombre %>!</h1>
                <p class="text-muted small mb-4">Maree Royalty</p>

                <div class="qr-container mb-4">
                    <div class="qr-placeholder mx-auto">
                        <% if (typeof qrCode !== 'undefined' && qrCode) { %>
                            <img src="<%= qrCode %>" alt="Código QR de <%= cliente.Nombre %>" class="img-fluid rounded shadow-sm">
                        <% } else { %>
                            <i class="bi bi-qr-code-scan text-danger"></i>
                            <span class="mt-2 small text-danger">Error al cargar QR</span>
                        <% } %>
                    </div>
                    <p class="text-muted mt-3 mb-0"><small><i class="bi bi-info-circle"></i> Muestra este código en caja</small></p>
                </div>

                <div class="royalty-stats row g-0">
                    <div class="stat-item col-6 border-end">
                        <span class="stat-label">Nivel</span>
                        <strong id="cliente-nivel-badge" class="badge-nivel mx-auto mt-1"><%= cliente.nivel %></strong>
                    </div>
                    <div class="stat-item col-6">
                        <span class="stat-label">Visitas</span>
                        <strong class="stat-value mt-1"><%= cliente.visitas %></strong>
                    </div>
                </div>
                
            </div>
        </div>
    </div>

    <section class="mb-4 ps-2 ps-md-0">
        <h2 class="section-title mb-3 fs-4">Tus Promociones</h2>
        <div class="scroll-horizontal pb-3" id="contenedor-promociones">
            <div class="w-100 text-center py-4 loading-state">
                <div class="spinner-border text-gold spinner-border-sm" role="status"></div> 
                <span class="ms-2 small">Cargando promociones...</span>
            </div>
        </div>
    </section>

    <section class="mb-4 ps-2 ps-md-0">
        <h2 class="section-title mb-3 fs-4">Tus Eventos</h2>
        <div class="scroll-horizontal pb-3" id="contenedor-eventos">
            <div class="w-100 text-center py-4 loading-state">
                <div class="spinner-border text-gold spinner-border-sm" role="status"></div> 
                <span class="ms-2 small">Cargando eventos...</span>
            </div>
        </div>
    </section>
    <section class="container-fluid px-2 px-md-3 mb-5">
        <div class="row g-3">
            <div class="col-12 col-md-6">
                <div class="card h-100 shadow-sm border-0 p-3" style="border-radius: 15px;">
                    <h3 class="fs-5 fw-bold mb-3"><i class="bi bi-heart-fill text-danger me-2"></i>Tus Favoritos</h3>
                    <div class="row">
                        <div class="col-6 border-end">
                            <p class="small fw-bold text-muted mb-2 text-uppercase" style="letter-spacing: 1px;">Bebidas</p>
                            <ul class="list-unstyled mb-0">
                                <% metrics.favoritos.bebidas.forEach(item => { %>
                                    <li class="small mb-2 text-truncate"><i class="bi bi-cup-hot me-1 text-gold"></i> <%= item.Nombre %></li>
                                <% }) %>
                            </ul>
                        </div>
                        <div class="col-6">
                            <p class="small fw-bold text-muted mb-2 text-uppercase" style="letter-spacing: 1px;">Platillos</p>
                            <ul class="list-unstyled mb-0">
                                <% metrics.favoritos.platillos.forEach(item => { %>
                                    <li class="small mb-2 text-truncate"><i class="bi bi-egg-fried me-1 text-gold"></i> <%= item.Nombre %></li>
                                <% }) %>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-12 col-md-6">
                <div class="card h-100 shadow-sm border-0 p-3" style="border-radius: 15px; background-color: #fdfaf5;">
                    <h3 class="fs-5 fw-bold mb-3"><i class="bi bi-trophy-fill text-warning me-2"></i>Lo más pedido</h3>
                    <div class="row">
                        <div class="col-6">
                            <p class="small fw-bold text-muted mb-2 text-uppercase">Top Bebidas</p>
                            <div class="list-group list-group-flush bg-transparent">
                                <% metrics.topGlobal.bebidas.forEach((item, index) => { %>
                                    <div class="list-group-item bg-transparent border-0 p-1 small">
                                        <span class="badge bg-gold text-dark rounded-circle me-1"><%= index + 1 %></span> <%= item.Nombre %>
                                    </div>
                                <% }) %>
                            </div>
                        </div>
                        <div class="col-6">
                            <p class="small fw-bold text-muted mb-2 text-uppercase">Top Platillos</p>
                            <div class="list-group list-group-flush bg-transparent">
                                <% metrics.topGlobal.platillos.forEach((item, index) => { %>
                                    <div class="list-group-item bg-transparent border-0 p-1 small">
                                        <span class="badge bg-gold text-dark rounded-circle me-1"><%= index + 1 %></span> <%= item.Nombre %>
                                    </div>
                                <% }) %>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
</main>

<script src="/js/Royalty/royalty.cliente.js"></script>
</body>
</html>