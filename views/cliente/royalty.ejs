<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Royalty - Marée</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bulma@1.0.4/css/bulma.min.css">
    <link rel="stylesheet" href="/css/menustyle.css">
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400&family=Jost:wght@300;400;500&display=swap" rel="stylesheet">
</head>
<body>
    <%- include('../partials/breadcrumbs') %>
    
    <main class="container my-5">
    <div class="royalty-header text-center mb-5">
        <h1 class="display-4">¡Hola, <%= cliente.Nombre %>!</h1>
        <p class="lead">Tu nivel actual es: <strong id="cliente-nivel-badge"><%= cliente.nivel %></strong></p>
        <p>Visitas acumuladas: <strong><%= cliente.visitas %></strong></p>
    </div>

    <hr>

    <section class="mb-5">
        <h2 class="mb-4">Tus Promociones Desbloqueadas</h2>
        <div class="row" id="contenedor-promociones">
            <div class="text-center"><div class="spinner-border text-primary" role="status"></div> Cargando promociones...</div>
        </div>
    </section>

    <section class="mb-5">
        <h2 class="mb-4">Tus Eventos Exclusivos</h2>
        <div class="row" id="contenedor-eventos">
            <div class="text-center"><div class="spinner-border text-primary" role="status"></div> Cargando eventos...</div>
        </div>
    </section>
</main>
    <script src="/js/Royalty/royalty.cliente.js"></script>
</body>
</html>