<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Registrar colaborador - Marée</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bulma@1.0.4/css/bulma.min.css">
  <link rel="stylesheet" href="/css/adminstyle.css">
</head>
<body>

<nav class="navbar" role="navigation">
  <div class="navbar-brand">
    <span class="navbar-item logo">MARÉE</span>
  </div>
</nav>

<section class="section">
  <div class="container">
    <h1 class="title">Registrar nuevo colaborador</h1>
    <p class="subtitle">Captura la información del nuevo empleado</p>

    <% if (error) { %>
      <div class="notification is-danger"><%= error %></div>
    <% } %>

    <div class="box">
      <form action="/admin/colaboradores/nuevo" method="POST">
        <div class="field">
          <label class="label">ID del colaborador</label>
          <div class="control">
            <input
              class="input"
              type="text"
              name="id_colaborador"
              value="<%= oldInput.id_colaborador %>"
              required>
          </div>
        </div>

        <div class="field">
          <label class="label">Nombre</label>
          <div class="control">
            <input
              class="input"
              type="text"
              name="nombre"
              value="<%= oldInput.nombre %>"
              required>
          </div>
        </div>

        <div class="field">
          <label class="label">Rol</label>
          <div class="control">
            <div class="select is-fullwidth">
              <select name="rol" required>
                <option value="Colaborador" <%= oldInput.rol === 'Colaborador' ? 'selected' : '' %>>Colaborador</option>
                <option value="Admin" <%= oldInput.rol === 'Admin' ? 'selected' : '' %>>Administrador</option>
              </select>
            </div>
          </div>
        </div>

        <div class="field">
          <label class="label">Contraseña</label>
          <div class="control">
            <input
              class="input"
              type="password"
              name="contrasena"
              required>
          </div>
        </div>

        <div class="field is-grouped mt-5">
          <div class="control">
            <button class="button is-primary" type="submit">Registrar colaborador</button>
          </div>
          <div class="control">
            <a href="/admin/colaboradores" class="button is-light">Cancelar</a>
          </div>
        </div>
      </form>
    </div>
  </div>
</section>

</body>
</html>