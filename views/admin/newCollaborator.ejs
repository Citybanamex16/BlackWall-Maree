<%- include('../partials/header_admin', { pageTitle: 'Registrar colaborador - Marée' }) %>
<%- include('../partials/breadcrumbs') %>

<main class="page-wrap">
  <header style="margin-bottom: 32px;">
    <h1 class="page-title">Registrar nuevo colaborador</h1>
    <p class="page-sub">Captura la información del nuevo empleado</p>
  </header>

  <% if (typeof error !== 'undefined' && error) { %>
    <div class="notification status-pill is-danger" style="border-radius: var(--radius-md); padding: 16px; width: 100%; margin-bottom: 24px;">
      <%= error %>
    </div>
  <% } %>

  <div class="card-base" style="max-width: 600px;">
    <form action="/admin/colaboradores/nuevo" method="POST">
      <div class="field mb-4">
        <label class="label" style="color: var(--c-text-muted); text-transform: uppercase; font-size: 11px; letter-spacing: 1px;">ID del colaborador</label>
        <div class="control">
          <input class="input input-base" type="text" name="id_colaborador" value="<%= oldInput ? oldInput.id_colaborador : '' %>" required>
        </div>
      </div>

      <div class="field mb-4">
        <label class="label" style="color: var(--c-text-muted); text-transform: uppercase; font-size: 11px; letter-spacing: 1px;">Nombre</label>
        <div class="control">
          <input class="input input-base" type="text" name="nombre" value="<%= oldInput ? oldInput.nombre : '' %>" required>
        </div>
      </div>

        <div class="field">
          <label class="label">Rol</label>
          <div class="control">
            <div class="select is-fullwidth">
              <select name="rol" required>
                <option value="Colaborador" <%= oldInput.rol === 'Colaborador' ? 'selected' : '' %>>Colaborador</option>
                <option value="Administrador" <%= oldInput.rol === 'Administrador' ? 'selected' : '' %>>Administrador</option>
              </select>
            </div>
          </div>
        </div>
      </div>

      <div class="field mb-5">
        <label class="label" style="color: var(--c-text-muted); text-transform: uppercase; font-size: 11px; letter-spacing: 1px;">Contraseña</label>
        <div class="control">
          <input class="input input-base" type="password" name="contrasena" required>
        </div>
      </div>

      <div class="field is-grouped" style="border-top: 1px solid var(--c-border); padding-top: 24px; margin-top: 16px;">
        <div class="control">
          <button class="btn-primary" type="submit">Registrar colaborador</button>
        </div>
        <div class="control">
          <a href="/admin/colaboradores" class="btn-ghost">Cancelar</a>
        </div>
      </div>
    </form>
  </div>
</main>

<script src="/js/admin.js"></script>
</body>
</html>