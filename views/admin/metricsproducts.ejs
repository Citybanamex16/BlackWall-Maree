<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= pageTitle %> - Admin Marée</title>

  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bulma@1.0.4/css/bulma.min.css">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;600&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

  <style>
    :root {
      --gold: #b5956a;
      --bg: #fdfaf7;
      --border: #ede8e0;
      --text: #222;
      --muted: #7a7a7a;
      --soft: #f7f1ea;
      --danger: #b94a48;
    }

    body {
      font-family: 'Jost', sans-serif;
      background: var(--bg);
      color: var(--text);
    }

    .navbar {
      background: #fff;
      border-bottom: 1px solid var(--border);
      padding: 10px 28px;
    }

    .logo-text {
      font-family: 'Cormorant Garamond', serif;
      font-size: 24px;
      letter-spacing: 4px;
      font-weight: 600;
    }

    .logo-sub {
      font-size: 10px;
      letter-spacing: 2px;
      color: var(--muted);
      text-transform: uppercase;
    }

    .page-wrap {
      max-width: 1300px;
      margin: 0 auto;
      padding: 28px;
    }

    .page-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: 44px;
      margin-bottom: 8px;
    }

    .page-subtitle {
      color: var(--muted);
      margin-bottom: 28px;
    }

    .card-box {
      background: #fff;
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 22px;
      margin-bottom: 20px;
    }

    .filters-grid,
    .kpi-grid,
    .two-grid {
      display: grid;
      gap: 16px;
    }

    .filters-grid {
      grid-template-columns: repeat(4, 1fr);
      align-items: end;
    }

    .kpi-grid {
      grid-template-columns: repeat(5, 1fr);
    }

    .two-grid {
      grid-template-columns: 1fr 1fr;
    }

    .kpi-card {
      background: #fff;
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 22px;
    }

    .kpi-label {
      font-size: 12px;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: 1px;
      margin-bottom: 12px;
    }

    .kpi-value {
      font-size: 34px;
      font-weight: 600;
      color: var(--gold);
    }

    .section-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: 28px;
      margin-bottom: 14px;
    }

    .small-note {
      font-size: 13px;
      color: var(--muted);
    }

    .status-box {
      display: none;
      margin-bottom: 16px;
      border-radius: 12px;
      padding: 14px 16px;
      font-size: 14px;
    }

    .status-box.error {
      display: block;
      background: #fff3f2;
      color: var(--danger);
      border: 1px solid #f0d2cf;
    }

    .status-box.info {
      display: block;
      background: #faf7f2;
      color: #8a6b45;
      border: 1px solid #eadfce;
    }

    .actions-row {
      display: flex;
      gap: 10px;
      justify-content: flex-end;
      margin-top: 12px;
      grid-column: 1 / -1;
    }

    .pill {
      display: inline-block;
      padding: 4px 10px;
      border-radius: 999px;
      background: var(--soft);
      color: #7a5c3a;
      font-size: 12px;
      font-weight: 600;
    }

    .loading {
      opacity: 0.6;
      pointer-events: none;
    }

    .chart-wrap {
      min-height: 340px;
    }

    @media (max-width: 1024px) {
      .filters-grid,
      .kpi-grid,
      .two-grid {
        grid-template-columns: 1fr 1fr;
      }
    }

    @media (max-width: 768px) {
      .filters-grid,
      .kpi-grid,
      .two-grid {
        grid-template-columns: 1fr;
      }

      .page-title {
        font-size: 34px;
      }
    }
  </style>
</head>
<body>
  <nav class="navbar">
    <div class="navbar-brand">
      <div class="navbar-item" style="display:flex; flex-direction:column; align-items:flex-start;">
        <div class="logo-text">MARÉE</div>
        <div class="logo-sub">Admin</div>
      </div>
    </div>
    <div class="navbar-end" style="display:flex;">
      <a href="/admin" class="navbar-item">Dashboard</a>
      <a href="/admin/metricas-productos" class="navbar-item" style="color: var(--gold);">
        Métricas productos
      </a>
    </div>
  </nav>

  <section class="page-wrap">
    <h1 class="page-title">Métricas de productos e ingredientes</h1>
    <p class="page-subtitle">
      Visualiza productos más vendidos, ingresos por categoría, ingredientes más usados,
      disponibilidad de insumos y productos afectados por ingredientes inactivos.
    </p>

    <div id="statusBox" class="status-box"></div>

    <div class="card-box">
      <h2 class="section-title">Filtros</h2>

      <form id="filtersForm" class="filters-grid">
        <div>
          <label class="label">Fecha inicio</label>
          <input class="input" type="date" name="fechaInicio">
        </div>

        <div>
          <label class="label">Fecha fin</label>
          <input class="input" type="date" name="fechaFin">
        </div>

        <div>
          <label class="label">Categoría</label>
          <div class="select is-fullwidth">
            <select name="categoria">
              <option value="">Todas</option>
              <option value="Platillo">Platillo</option>
              <option value="Bebidas">Bebidas</option>
            </select>
          </div>
        </div>

        <div>
          <label class="label">Tipo</label>
          <input class="input" type="text" name="tipo" placeholder="Ej. Especiales, Saladas, Frappes">
        </div>

        <div class="actions-row">
          <button type="button" id="btnLimpiar" class="button is-light">Limpiar</button>
          <button type="submit" class="button" style="background:#b5956a; color:white;">
            Consultar métricas
          </button>
          <button type="button" id="btnExportar" class="button is-dark">
            Exportar CSV
          </button>
        </div>
      </form>
    </div>

    <div id="dashboardContent">
      <div class="kpi-grid">
        <div class="kpi-card">
          <div class="kpi-label">Productos vendidos</div>
          <div id="kpiProductosVendidos" class="kpi-value">0</div>
        </div>

        <div class="kpi-card">
          <div class="kpi-label">Unidades vendidas</div>
          <div id="kpiUnidadesVendidas" class="kpi-value">0</div>
        </div>

        <div class="kpi-card">
          <div class="kpi-label">Ingresos totales</div>
          <div id="kpiIngresos" class="kpi-value">$0</div>
        </div>

        <div class="kpi-card">
          <div class="kpi-label">Ingredientes utilizados</div>
          <div id="kpiIngredientes" class="kpi-value">0</div>
        </div>

        <div class="kpi-card">
          <div class="kpi-label">Productos afectados</div>
          <div id="kpiAfectados" class="kpi-value">0</div>
        </div>
      </div>

      <div class="two-grid" style="margin-top:20px;">
        <div class="card-box">
          <h2 class="section-title">Top productos por cantidad</h2>
          <div class="chart-wrap">
            <canvas id="chartTopCantidad"></canvas>
          </div>
        </div>

        <div class="card-box">
          <h2 class="section-title">Ingresos por categoría</h2>
          <div class="chart-wrap">
            <canvas id="chartCategoriaIngresos"></canvas>
          </div>
        </div>
      </div>

      <div class="two-grid">
        <div class="card-box">
          <h2 class="section-title">Ingredientes más populares</h2>
          <div class="chart-wrap">
            <canvas id="chartIngredientes"></canvas>
          </div>
        </div>

        <div class="card-box">
          <h2 class="section-title">Tendencia de consumo</h2>
          <div class="chart-wrap">
            <canvas id="chartTendencia"></canvas>
          </div>
        </div>
      </div>

      <div class="two-grid">
        <div class="card-box">
          <h2 class="section-title">Top productos por ingresos</h2>
          <p class="small-note">Ranking económico por rango seleccionado</p>

          <div class="table-container" style="margin-top:14px;">
            <table class="table is-fullwidth is-hoverable">
              <thead>
                <tr>
                  <th>Producto</th>
                  <th>Categoría</th>
                  <th>Vendidas</th>
                  <th>Ingresos</th>
                </tr>
              </thead>
              <tbody id="topIngresosBody">
                <tr><td colspan="4">Sin datos aún</td></tr>
              </tbody>
            </table>
          </div>
        </div>

        <div class="card-box">
          <h2 class="section-title">Disponibilidad de ingredientes</h2>
          <p class="small-note">Comparación global de insumos activos vs inactivos</p>

          <div style="margin-top:18px;">
            <p><span class="pill">Activos</span> <strong id="ingredientesActivos">0</strong></p>
            <p style="margin-top:12px;"><span class="pill">Inactivos</span> <strong id="ingredientesInactivos">0</strong></p>
          </div>
        </div>
      </div>

      <div class="card-box">
        <h2 class="section-title">Productos afectados por ingredientes inactivos</h2>
        <p class="small-note">Ayuda para identificar recetas potencialmente comprometidas</p>

        <div class="table-container" style="margin-top:14px;">
          <table class="table is-fullwidth is-hoverable">
            <thead>
              <tr>
                <th>Producto</th>
                <th>Categoría</th>
                <th># insumos inactivos</th>
                <th>Detalle</th>
              </tr>
            </thead>
            <tbody id="productosAfectadosBody">
              <tr><td colspan="4">Sin datos aún</td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>

  <script src="/js/adminmetricsproductos.js"></script>
</body>
</html>