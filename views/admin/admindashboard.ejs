<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Admin Dashboard - Marée</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;600&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bulma@1.0.4/css/bulma.min.css">
    <link rel="stylesheet" href="/css/adminstyle.css">
</head>

<body>

<!-- NAV — same structure as menu page -->
<nav class="navbar" role="navigation">
    <div class="navbar-brand">
        <div class="navbar-item">
            <div class="logo-area">
                <span class="logo-text">MARÉE</span>
                <span class="logo-sub">Love at First Crêpe</span>
            </div>
        </div>
    </div>
</nav>

<%- include('../partials/breadcrumbs') %>

<section class="section">
    <div class="container">

        <h1 class="title">Admin Dashboard</h1>
        <p class="subtitle">Manage your cafeteria operations</p>

        <hr class="admin-section-divider">

        <div class="dashboard-grid">

            <a href="/admin/ingredientes" class="box dashboard-card">
                <div class="icon-circle blue">📦</div>
                <p>Ingredients</p>
            </a>

            <a href="/menu/productos" class="box dashboard-card">
                <div class="icon-circle green">🛍️</div>
                <p>Products</p>
            </a>
            
            <a href="/admin/metricas-productos" class="box dashboard-card">
                <div class="icon-circle blue">📊</div>
                <p>Product Metrics</p>
            </a>

            <a href="/royalty/royaltyAdmin" class="box dashboard-card">
                <div class="icon-circle yellow">🏅</div>
                <p>Royalty System</p>
            </a>

            <a href="/admin/colaboradores" class="box dashboard-card">
                <div class="icon-circle purple">👥</div>
                <p>Collaborators</p>
            </a>

            <a href="/admin/ordenes" class="box dashboard-card">
                <div class="icon-circle red">📋</div>
                <p>Active Orders</p>
            </a>

            <a href="/promos/promociones" class="box dashboard-card">
                <div class="icon-circle pink">🏷️</div>
                <p>Promotions</p>
            </a>

            <a href="/promos/eventos" class="box dashboard-card">
                <div class="icon-circle teal">📅</div>
                <p>Events</p>
            </a>

            <a href="/admin/mensajes" class="box dashboard-card">
                <div class="icon-circle whatsapp">💬</div>
                <p>WhatsApp</p>
            </a>

        </div>
    </div>
</section>

<script src="/js/admin.js"></script>
</body>
</html>
