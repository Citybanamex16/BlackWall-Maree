<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Admin Dashboard - Marée</title>
    
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bulma@1.0.4/css/bulma.min.css">
    <link rel="stylesheet" href="/css/adminstyle.css">
</head>

<body>

<nav class="navbar" role="navigation">
    <div class="navbar-brand">
        <span class="navbar-item logo">MARÉE</span>
    </div>
    <div class="navbar-menu">
        <div class="navbar-end">
            <a href="/" class="navbar-item">Menu</a>
            <a href="/cliente/hours" class="navbar-item">Hours</a>
            <a href="/cliente/promotions" class="navbar-item">Promotions</a>
            <a href="/cliente/record" class="navbar-item">Record Visit</a>
            <a href="/admin" class="navbar-item active-link">Admin</a>
        </div>
    </div>
</nav>

<section class="section">
    <div class="container">

        <h1 class="title">Admin Dashboard</h1>
        <p class="subtitle">Manage your cafeteria operations</p>

        <div class="grid dashboard-grid">

            <div class="cell">
                <a href="/admin/ingredients" class="box dashboard-card">
                    <div class="icon-circle blue">📦</div>
                    <p>Ingredients</p>
                </a>
            </div>

            <div class="cell">
                <a href="/admin/products" class="box dashboard-card">
                    <div class="icon-circle green">🛍️</div>
                    <p>Products</p>
                </a>
            </div>

            <div class="cell">
                <a href="/admin/royalty" class="box dashboard-card">
                    <div class="icon-circle yellow">🏅</div>
                    <p>Royalty System</p>
                </a>
            </div>

            <div class="cell">
                <a href="/admin/collaborators" class="box dashboard-card">
                    <div class="icon-circle purple">👥</div>
                    <p>Colaborators/Employees</p>
                </a>
            </div>

            <div class="cell">
                <a href="/admin/orders" class="box dashboard-card">
                    <div class="icon-circle red">📋</div>
                    <p>Active Orders</p>
                </a>
            </div>

            <div class="cell">
                <a href="/admin/promotions" class="box dashboard-card">
                    <div class="icon-circle pink">🏷️</div>
                    <p>Promotions</p>
                </a>
            </div>

            <div class="cell">
                <a href="/admin/events" class="box dashboard-card">
                    <div class="icon-circle teal">📅</div>
                    <p>Events</p>
                </a>
            </div>

            <div class="cell">
                <a href="/admin/whatsapp" class="box dashboard-card">
                    <div class="icon-circle whatsapp">💬</div>
                    <p>WhatsApp</p>
                </a>
            </div>

        </div>
    </div>
</section>

<script src="/js/admin.js"></script>
</body>
</html>