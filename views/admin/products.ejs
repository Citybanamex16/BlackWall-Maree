<%- include('../partials/header_admin', { pageTitle: 'Catálogo de Productos - Marée' }) %>
<%- include('../partials/breadcrumbs') %>

<main class="page-wrap">
  <header style="margin-bottom: 32px;">
    <h1 class="page-title">Catálogo de Productos</h1>
    <p class="page-sub">Aquí va el catálogo de productos</p>
  </header>

  <div class="card-base" style="min-height: 400px; display:flex; align-items:center; justify-content:center; color: var(--c-text-muted);">
      <p>Contenido del catálogo de productos...</p>
  </div>

  <a href="#" id="registrarNuevoProducto" class="btn-primary fab" style="border-radius: var(--radius-pill); padding: 14px 24px; display: flex; align-items: center; gap: 8px;">
    <span class="icon">
        <i class="fas fa-plus"></i> </span>
    <span>Añadir Producto</span>
  </a>
</main>

<dialog id="TypeFormsCU04" class="card-base" style="padding: 32px; border: none; max-width: 400px;">
  <button class="delete is-pulled-right" id="closeRegisterX" style="background: var(--c-border);"></button>
  <h2 id="tituloModal" class="page-title" style="font-size: 24px; margin-bottom: 16px;">Título dinámico</h2>
  <p style="color: var(--c-text-muted);">Elige una opción:</p>
  <br>
  <button id="cerrarModal" class="btn-ghost" style="margin-top: 10px; width: 100%;">Cerrar</button>
</dialog>

<dialog id="RegisterFormsCU04" class="card-base" style="padding: 32px; border: none; max-width: 600px; width: 90%;">
  <button class="delete is-pulled-right" id="closeRegisterX" style="background: var(--c-border);"></button>
  <h2 id="FormTitleModal" class="page-title" style="font-size: 24px; margin-bottom: 8px;">Título dinámico</h2>
  <p style="color: var(--c-text-muted);">Llena los datos requeridos</p>
  <hr style="border:none; border-top:1px solid var(--c-border); margin: 16px 0;">

  <div id="formsContainer"></div>

  <div style="display: flex; justify-content: flex-end; gap: 12px; margin-top: 24px;">
    <button id="cerrarFormModal" type="button" class="btn-ghost">Cancelar</button>
    <button id="submitFormsRegistrar" type="submit" form="formsRegistrarForm" class="btn-primary">Guardar</button>
  </div>
</dialog>

<dialog id="SummaryCU04" class="card-base" style="padding: 32px; border: none; max-width: 500px; width: 90%;">
  <button class="delete is-pulled-right" id="closeRegisterX" style="background: var(--c-border);"></button>
  <h2 id="SummaryTitleModal" class="page-title" style="font-size: 24px; margin-bottom: 8px;">Título dinámico</h2>
  <p style="color: var(--c-text-muted);">Revisa los datos antes de registrar</p>
  <hr style="border:none; border-top:1px solid var(--c-border); margin: 16px 0;">

  <div id="summaryContent" style="margin-bottom: 24px;"></div> 

  <div style="display: flex; justify-content: flex-end; gap: 12px;">
    <button id="cerrarSummaryModal" type="button" class="btn-ghost">Cerrar</button>
    <button id="RegisterProduct" type="button" class="btn-primary">Registrar Producto</button>
  </div>
</dialog>

<dialog id="ModalExito" class="card-base" style="padding: 32px; border: none; max-width: 400px; text-align: center;">
  <div style="font-size: 48px; margin-bottom: 16px; color: var(--c-success);">✓</div>
  <h2 id="TituloExito" class="page-title" style="font-size: 28px; margin-bottom: 12px;">Titulo Dinamico</h2>
  <p id="exitoContent" style="color: var(--c-text-muted); margin-bottom: 24px;">Contenido Dinámico</p>
  <button id="closeExito" class="btn-success" style="width: 100%;">Regresar a Catalogo</button>
</dialog>

<dialog id="ErrorModal" class="card-base" style="padding: 32px; border: none; max-width: 400px; text-align: center;">
  <div style="font-size: 48px; margin-bottom: 16px; color: var(--c-danger);">⚠️</div>
  <h2 id="ErrorTitle" class="page-title" style="font-size: 28px; margin-bottom: 12px;">Titulo Dinámico</h2>
  <p id="errorContent" style="color: var(--c-text-muted); margin-bottom: 24px;">Contenido Dinámico</p>
  <button id="closeError" class="btn-danger" style="width: 100%;">Regresar a Catalogo</button>
</dialog>

</body>
</html>