<!DOCTYPE html>
<html lang="es" data-theme="light">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Feedback - Admin Marée</title>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet">

  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bulma@1.0.4/css/bulma.min.css">
  <link rel="stylesheet" href="/css/CSSglobales/global_theme.css">
  <link rel="stylesheet" href="/css/CSSglobales/global_components.css">
  <link rel="stylesheet" href="/css/moduloMenuCSS/moduloMenuAdminCSS.css">
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body>

<!-- NAVBAR -->
<nav class="navbar" role="navigation">
  <div class="navbar-brand">
    <div class="navbar-item">
      <div class="logo-area">
        <span class="logo-text">MARÉE</span>
        <span class="logo-sub">Love at First Crêpe</span>
      </div>
    </div>
  </div>
</nav>

<section class="section">
  <div class="container">

    <a href="/admin" class="back-link">← Admin Dashboard</a>
    
    <div class="ing-header">
      <div>
        <h1 class="page-title">Feedback</h1>
        <p class="page-sub">Historial de comentarios y calificaciones de clientes</p>
      </div>
    </div>

    <!-- KPI -->
    <div class="kpi-grid" style="margin-bottom:32px;">
      <div class="kpi-card">
        <p class="kpi-label">Promedio general</p>
        <p class="kpi-value" id="kpi-promedio">—</p>
      </div>
      <div class="kpi-card">
        <p class="kpi-label">Total reviews</p>
        <p class="kpi-value" id="kpi-total">—</p>
      </div>
      <div class="kpi-card">
        <p class="kpi-label">Positivas (4-5 ★)</p>
        <p class="kpi-value" id="kpi-positivas">—</p>
      </div>
      <div class="kpi-card">
        <p class="kpi-label">Más reciente</p>
        <p class="kpi-value" id="kpi-reciente" style="font-size:22px;">—</p>
      </div>
    </div>

    <!-- Barra filtro -->
    <div id="seccion-filtros" class="feedback-filtros">
      <div class="filtro-grupo">
        <label class="filtro-label">Período</label>
        <div class="select">
          <select id="filtro-date">
            <option value="0">Todo el historial</option>
            <option value="1">Hoy</option>
            <option value="7">Esta semana</option>
            <option value="30" selected>Este mes</option>
            <option value="90">Este trimestre</option>
          </select>
        </div>
      </div>

      <div class="filtro-grupo">
        <label class="filtro-label">Puntaje</label>
        <div class="select">
          <select id="filtro-puntaje">
            <option value="todos">Todos</option>
            <option value="5">★★★★★</option>
            <option value="4">★★★★</option>
            <option value="3">★★★</option>
            <option value="2">★★</option>
            <option value="1">★</option>
          </select>
        </div>
      </div>

      <div class="filtro-grupo">
        <label class="filtro-label">ID de orden</label>
        <input id="filtro-id" class="maree-input" type="text" placeholder="Ej. OD20045010" style="max-width:200px;">
      </div>

      <p class="filtro-resultado" id="filtro-conteo">— comentarios</p>

      <button id="btn-filtrar" class="btn-maree">Filtrar</button>
    </div>

    <!-- Layout -->
    <div class="feedback-layout">
      <div id="seccion-comentarios" class="comentarios-columna">
        <div class="reviews-empty">
          <span class="reviews-empty-icon">💬</span>
          <p>Cargando comentarios...</p>
        </div>
      </div>

      <aside id="seccion-kpis" class="kpis-columna">
        <p class="chart-title" style="margin-bottom:4px;">Satisfacción por mes</p>
        <p class="chart-sub">Promedio de puntaje mensual</p>
        <div style="position:relative; height:260px;">
          <canvas id="kpi-chart"></canvas>
        </div>
      </aside>
    </div>

  </div>
</section>

<!-- MODAL Detalle de comentario -->
<dialog id="ModalDetalleReview" class="maree-modal">
  <div class="modal-inner">
    <p class="modal-title">Detalle de Review</p>
    <p class="modal-sub" id="detalle-subtitulo">Orden —</p>

    <div class="resumen-fila">
      <span class="resumen-label">ID Review</span>
      <span class="resumen-valor" id="detalle-id">—</span>
    </div>
    <div class="resumen-fila">
      <span class="resumen-label">ID Orden</span>
      <span class="resumen-valor" id="detalle-orden">—</span>
    </div>
    <div class="resumen-fila">
      <span class="resumen-label">Puntaje</span>
      <span class="resumen-valor" id="detalle-estrellas">—</span>
    </div>
    <div class="resumen-fila">
      <span class="resumen-label">Fecha</span>
      <span class="resumen-valor" id="detalle-fecha">—</span>
    </div>
    <div class="resumen-fila" style="flex-direction:column; gap:6px;">
      <span class="resumen-label">Comentario</span>
      <span class="resumen-valor" id="detalle-comentario" style="line-height:1.6;">—</span>
    </div>

    <div class="modal-actions">
      <button id="btnCerrarDetalle" class="btn-secondary" style="flex:1;">Cerrar</button>
    </div>
  </div>
</dialog>

<script src="/js/menudigital/feedbackScripts/feedbackCatalog.js"></script>
<script src="/js/adminOrderNotifications.js"></script>
</body>
</html>
