<!DOCTYPE html>
<html lang="es" data-theme="light">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Royalty - Admin Marée</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bulma@1.0.4/css/bulma.min.css">
    <!--CSS creados-->
    <link rel="stylesheet" href="/css/CSSglobales/global_components.css">
    <link rel="stylesheet" href="/css/CSSglobales/global_theme.css">
    <link rel="stylesheet" href="/css/CSSglobales/adminstyle.css">
    <link rel="stylesheet" href="/css/moduloRoyaltyCSS/royalty-admin.css">
  
    <link rel="stylesheet" href="/css/CSSglobales/adminstyle.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
</head>
<body>
    <section class="section">
        <div class="container">
            <h1 class="title">Catálogo de Royalty System</h1>
            <!-- onclick = abrirModal()-->
             <br>
             <div class="button is-primary is-rounded">
                    <!-- Agregar la funcionalidad de abrirModal-->
                     <br>
                        <button class="button is-primary" onclick="abrirModalNuevoEstadoRoyalty()">Nuevo Estado Royalty</button>
                        
                </div>
                <br>
            <section class="section">
            <div id="royaltyContainer"></div>
            </section>
        </div>
        
    </section>

    <section class = " box ">
        <form action="/royalty/royaltyAdmin/metricsRoyalty" method="GET">
            <input class="button" type="submit" value="View Metrics" />
        </form>
    </section>

    <!-- Pop- up  Modificar estado royalty -->
     <div class="modal" id="modal-modificarRoyalty">
        <div class="modal-background"></div>
        <div class="modal-content">
            <div class="box">
                <h3 class="title is-4">Modificar <span id="modal-nombre"></span></h3>
                <form id="form-modificarRoyalty">
                    <div class="field">
                        <label class="label">Nombre</label>
                        <div class="control">
                            <input id="input-nombre" class="input" type="text">
                        </div>
                    </div>
                    <div class="field">
                        <label class="label">Prioridad</label>
                        <div class="control">
                            <input id="input-prioridad" class="input" type="number">
                        </div>
                        <p id="recordatorio-prioridad" class="help has-text-info"></p>
                    </div>
                    <div class="field">
                        <label class="label">Descripcion</label>
                        <div class="control">
                            <input id="input-descripcion" class="input" type="text">
                        </div>
                    </div>
                    <div class="field">
                        <label class="label">Visitas mínimas</label>
                        <div class="control">
                            <input id="input-minVisitas" class="input" type="number">
                        </div>
                        <p id="recordatorio-visitas" class="help has-text-info"></p>
                    </div>
                    <div class="field">
                        <label class="label">Visitas máximas</label>
                        <div class="control">
                            <input id="input-maxVisitas" class="input" type="number">
                        </div>
                    </div>
                    <div class="field">
                        <label class="label">Descuento Premio</label>
                        <div class="control">
                            <input id="input-descuentos_premios" class="input" type="number">
                        </div>
                    </div>
                    <div class="field">
                        <label class="label">Promociones</label>
                        <div id="contenedor-promociones" class="box" style="max-height: 150px; overflow-y: auto;">
                            <p class="has-text-grey">Cargando...</p>
                        </div>
                    </div>
                    <div class="field">
                        <label class="label">Eventos</label>
                        <div id="contenedor-eventos" class="box" style="max-height: 150px; overflow-y: auto;">
                            <p class="has-text-grey">Cargando...</p>
                        </div>
                    </div>
                    <div class="buttons">
                        <button type="button" class="button is-primary" onclick="guardarRoyalty()"> Guardar </button>
                        <button type="button" class="button" onclick="cerrarModal()">Cancelar</button>
                    </div>
                </form>
            </div>
        </div>
     </div>

     <!-- Pop-up  Agregar estado royalty -->
     <div class="modal" id="modalAgregarRoyalty">
        <div class="modal-background"></div>
        <div class="modal-content">
            <div class="box">
                <h3 class="title is-4">Agregar Royalty<span id="modal-nombre"></span></h3>
                <form id="form-modificarRoyalty">
                    <div class="field">
                        <label class="label">Nombre</label>
                        <div class="control">
                            <input id="add-input-nombre" class="input" type="text">
                        </div>
                    </div>
                    <div class="field">
                        <label class="label">Prioridad</label>
                        <div class="control">
                            <input id="add-input-prioridad" class="input" type="number">
                        </div>
                        <p id="add-recordatorio-prioridad" class="help has-text-info"></p>
                    </div>
                    <div class="field">
                        <label class="label">Descripcion</label>
                        <div class="control">
                            <input id="add-input-descripcion" class="input" type="text">
                        </div>
                    </div>
                    <div class="field">
                        <label class="label">Visitas mínimas</label>
                        <div class="control">
                            <input id="add-input-minVisitas" class="input" type="number">
                        </div>
                        <p id="add-recordatorio-visitas" class="help has-text-info"></p>
                    </div>
                    <div class="field">
                        <label class="label">Visitas máximas</label>
                        <div class="control">
                            <input id="add-input-maxVisitas" class="input" type="number">
                        </div>
                    </div>
                    <div class="field">
                        <label class="label">Descuento Premio</label>
                        <div class="control">
                            <input id="add-input-descuento_premio" class="input" type="number">
                        </div>
                    </div>
                    <!--Promociones-->
                    <div class="field">
                        <label class="label">Promociones</label>
                        <div id="contenedor-promociones-nuevo" class="box" style="max-height: 150px; overflow-y: auto;">
                            <p class="has-text-grey">Cargando...</p>
                        </div>
                    </div>
                    <div class="field">
                        <label class="label">Eventos</label>
                        <div id="contenedor-eventos-nuevo" class="box" style="max-height: 150px; overflow-y: auto;">
                            <p class="has-text-grey">Cargando...</p>
                        </div>
                    </div>
                    <!--Eventos-->
                    <div class="buttons">
                        <button type="button" class="button is-primary" onclick="RegistroGuardarRoyalty()"> Guardar </button>
                        <button type="button" class="button" onclick="cerrarModalGuardarRoyalty()">Cancelar</button>
                    </div>
                </form>
            </div>
        </div>
     </div>
    <!-- Pop up Confirmacion de modificar estado royalty-->
    <div class="modal" id="modal-confirmarModificarRoyalty">
    <div class="modal-background"></div>
    <div class="modal-content">
        <div class="box has-text-centered">
            <h3 class="title is-4">¿Deseas guardar los cambios?</h3>
            <div class="buttons">
                <button type="button" class="button is-primary" onclick="cerrarModalConfirmacion()">Confirmar</button>
                <button type="button" class="button" onclick="cerrarModalSoloConfirmacion()">Cancelar</button>
            </div>
        </div>
    </div>
</div>

<!--MODAL Error-->
<div id="ModalError" class="modal">
  <div class="modal-background"></div>
  <div class="modal-content">
    <div class="box has-text-centered">
      <span class="icon has-text-warning" style="font-size: 3rem;">⚠️</span>
      <p class="title is-4" id="errorTitulo">Error</p>
      <p id="errorMensaje" style="font-size:14px;color:#555;margin-bottom:24px;"></p>
      <button class="button is-danger" onclick="cerrarModalError()">Cerrar</button>
    </div>
  </div>
</div>

<!-- MODAL eliminar -->
<div id="ModalEliminar" class="modal">
  <div class="modal-background"></div>
  <div class="modal-content">
    <div class="box has-text-centered">
      <span class="icon has-text-warning" style="font-size: 3rem;">
        <i class="fas fa-exclamation-triangle"></i>
      </span>
      <p class="mt-3">¿Estás seguro que deseas borrar <strong><span id="nombre-a-borrar"></span></strong>?</p>
      <div class="buttons is-centered mt-4">
        <button class="button is-danger" onclick="confirmarBorrado()">Aceptar</button>
        <button class="button" onclick="document.getElementById('ModalEliminar').classList.remove('is-active')">Cancelar</button>
      </div>
    </div>
  </div>
</div>
<!--Modal exito-->
<div id="modal-exito" class="modal">
  <div class="modal-background"></div>
  <div class="modal-content">
    <div class="box has-text-centered">
      <h3 class="title is-4 mt-4">¡Registro Exitoso!</h3>
      <p id="mensaje-exito">La promoción se ha guardado correctamente.</p>
      <button class="button is-primary mt-5" onclick="location.reload()">Continuar</button>
    </div>
  </div>
</div>
    </div>
  </div>
</div>

    <script src = "/js/Royalty/royalty.admin.js"></script>
<script src="/js/adminOrderNotifications.js"></script>
</body>
</html>