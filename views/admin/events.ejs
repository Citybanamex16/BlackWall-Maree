<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Events - Admin Maree</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bulma@1.0.4/css/bulma.min.css">
    <link rel="stylesheet" href="/css/adminstyle.css">
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;600&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet">
    <style>
        :root {
            --maree-accent: #b5956a;
            --maree-accent-strong: #9f7c4e;
            --maree-accent-soft: #f5ede0;
            --maree-ink: #2b2722;
            --maree-muted: #8b8377;
            --maree-border: #eadfce;
            --maree-card: #fffdf9;
            --maree-bg: #fcfaf6;
            --maree-danger: #cb6b74;
            --maree-danger-soft: #fff2f3;
            --maree-success: #4f9f75;
            --maree-success-soft: #eef8f1;
        }

        body {
            font-family: 'Jost', sans-serif;
            color: var(--maree-ink);
            background:
                radial-gradient(circle at top left, rgba(245, 237, 224, 0.85), transparent 32%),
                linear-gradient(180deg, #ffffff 0%, var(--maree-bg) 62%, #f6efe3 100%);
            min-height: 100vh;
        }

        .events-shell {
            max-width: 1240px;
            padding: 0 24px;
        }

        .events-toolbar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 16px;
            margin-bottom: 20px;
        }

        .events-return {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            border: 1px solid var(--maree-border);
            border-radius: 999px;
            padding: 10px 18px;
            background: rgba(255, 255, 255, 0.8);
            color: #6c5c47;
            font-size: 14px;
            font-weight: 500;
            text-decoration: none;
            transition: border-color 0.2s, background 0.2s, transform 0.2s, box-shadow 0.2s;
        }

        .events-return:hover {
            border-color: var(--maree-accent);
            background: #fff;
            box-shadow: 0 8px 18px rgba(181, 149, 106, 0.16);
            color: var(--maree-accent-strong);
            transform: translateY(-1px);
        }

        .events-heading {
            margin-bottom: 20px !important;
        }

        .events-copy .title {
            font-family: 'Cormorant Garamond', serif;
            font-size: clamp(3rem, 5vw, 4.5rem);
            font-weight: 400;
            letter-spacing: 0.3px;
            line-height: 0.92;
            color: var(--maree-ink);
            margin-bottom: 8px !important;
        }

        .events-copy .subtitle {
            max-width: 620px;
            color: var(--maree-muted) !important;
            font-size: 15px !important;
            line-height: 1.7;
        }

        #btn-registrar-evento {
            background: var(--maree-accent);
            color: #fff;
            border: none;
            box-shadow: 0 12px 24px rgba(181, 149, 106, 0.24);
            transition: transform 0.2s, box-shadow 0.2s, background 0.2s;
        }

        #btn-registrar-evento:hover {
            background: var(--maree-accent-strong);
            transform: translateY(-1px);
            box-shadow: 0 16px 28px rgba(181, 149, 106, 0.3);
        }

        #loading-spinner.button {
            background: transparent;
            color: var(--maree-accent);
        }

        #feedback-eventos.notification {
            border-radius: 18px;
            border: 1px solid var(--maree-border);
            background: rgba(255, 255, 255, 0.85);
            color: var(--maree-ink);
            box-shadow: 0 18px 38px rgba(181, 149, 106, 0.08);
        }

        #feedback-eventos.notification.is-success {
            background: var(--maree-success-soft);
            border-color: #cfe6d8;
            color: #35674a;
        }

        #feedback-eventos.notification.is-danger {
            background: var(--maree-danger-soft);
            border-color: #f0d2d5;
            color: #8d4b53;
        }

        .event-card {
            height: 100%;
            border: 1px solid var(--maree-border);
            border-radius: 22px;
            background: linear-gradient(180deg, var(--maree-card) 0%, #ffffff 100%);
            box-shadow: 0 18px 40px rgba(181, 149, 106, 0.1);
            transition: transform 0.22s ease, box-shadow 0.22s ease, border-color 0.22s ease;
            overflow: hidden;
        }

        .event-card:hover {
            transform: translateY(-4px);
            border-color: #dcbc94;
            box-shadow: 0 24px 46px rgba(181, 149, 106, 0.18);
        }

        .event-card .card-content {
            padding: 28px 28px 22px;
        }

        .event-card .title.is-5 {
            font-family: 'Cormorant Garamond', serif !important;
            font-size: clamp(2.2rem, 3vw, 3.45rem) !important;
            font-weight: 400 !important;
            line-height: 0.98 !important;
            color: var(--maree-accent) !important;
            max-width: 82%;
            margin-bottom: 14px !important;
        }

        .event-card .subtitle.is-7 {
            color: #99846a !important;
            letter-spacing: 2px;
            font-size: 11px !important;
        }

        .event-card .content {
            min-height: 110px;
            color: #5e5a53 !important;
            font-size: 16px;
            line-height: 1.75;
        }

        .event-card hr {
            background-color: #ece2d4 !important;
            height: 1px;
        }

        .event-date-tag {
            display: block;
            margin-top: 4px;
            color: var(--maree-accent);
            font-size: 15px;
            font-weight: 600;
            line-height: 1.6;
        }

        .event-card .card-footer {
            border-top: 1px solid #f0e7da !important;
            background: rgba(255, 255, 255, 0.92) !important;
        }

        .event-card .card-footer-item {
            padding: 18px 12px;
            font-size: 15px;
            font-weight: 500;
            transition: background 0.2s, color 0.2s;
        }

        .event-card .card-footer-item + .card-footer-item {
            border-left: 1px solid #f0e7da;
        }

        .event-card .card-footer-item:hover {
            background: var(--maree-accent-soft);
        }

        .event-card [data-event-action="modificar"] {
            color: var(--maree-accent-strong) !important;
        }

        .event-card [data-event-action="estado"] {
            color: var(--maree-danger) !important;
        }

        .modal-background {
            backdrop-filter: blur(6px);
            background: rgba(43, 39, 34, 0.38);
        }

        #modal-formulario-evento .modal-content {
            width: min(960px, 92vw);
        }

        #modal-accion-evento .modal-content,
        #modal-confirmacion-evento .modal-content {
            width: min(560px, 92vw);
        }

        .events-modal-box {
            border-radius: 26px;
            border: 1px solid var(--maree-border);
            background: linear-gradient(180deg, #fffdf8 0%, #ffffff 100%);
            box-shadow: 0 28px 80px rgba(43, 39, 34, 0.16);
            padding: 32px;
        }

        #titulo-form-evento,
        #modal-accion-evento .title,
        #modal-confirmacion-evento .title {
            font-family: 'Cormorant Garamond', serif;
            font-size: clamp(2.7rem, 4vw, 4rem);
            font-weight: 400;
            color: var(--maree-ink);
            letter-spacing: 0.2px;
        }

        #modo-form-evento {
            border: 1px solid #e8dcc8;
            border-radius: 999px;
            padding: 0.45rem 0.9rem;
            background: #f5f0e8;
            color: #8a7455;
            font-size: 13px;
            font-weight: 500;
        }

        #form-evento .label {
            color: #8a7556;
            font-size: 14px;
            font-weight: 600;
            letter-spacing: 0.25px;
        }

        #form-evento .input,
        #form-evento .select select {
            border: 1px solid var(--maree-border);
            border-radius: 14px;
            background: #fffdf9;
            color: var(--maree-ink);
            box-shadow: none;
            transition: border-color 0.2s, box-shadow 0.2s, background 0.2s;
        }

        #form-evento .input {
            min-height: 52px;
        }

        #form-evento .input:focus,
        #form-evento .select select:focus {
            border-color: var(--maree-accent);
            background: #fff;
            box-shadow: 0 0 0 4px rgba(181, 149, 106, 0.12);
        }

        #form-evento .select {
            display: block;
        }

        #form-evento .select.is-multiple {
            width: 100%;
        }

        #form-evento .select select {
            width: 100%;
            min-height: 180px;
            padding: 10px;
        }

        #form-evento .select select option {
            padding: 12px 14px;
            border-radius: 12px;
        }

        #form-evento .button.is-light,
        #modal-accion-evento .button.is-light,
        #modal-confirmacion-evento .button.is-light {
            border-color: var(--maree-border);
            color: #6b5c47;
            background: #fff;
        }

        #form-evento .button.is-primary,
        #form-evento .button.is-link {
            background: var(--maree-accent);
            border-color: transparent;
            color: #fff;
        }

        #form-evento .button.is-primary:hover,
        #form-evento .button.is-link:hover {
            background: var(--maree-accent-strong);
        }

        #modal-accion-evento .button.is-warning,
        #modal-confirmacion-evento .button.is-warning {
            background: var(--maree-accent);
            border-color: transparent;
            color: #fff;
        }

        #modal-accion-evento .button.is-success,
        #modal-confirmacion-evento .button.is-success {
            background: var(--maree-success);
            border-color: transparent;
            color: #fff;
        }

        #modal-accion-evento .button.is-danger,
        #modal-confirmacion-evento .button.is-danger {
            background: var(--maree-danger);
            border-color: transparent;
            color: #fff;
        }

        .modal-close {
            background: rgba(181, 149, 106, 0.18);
        }

        @media screen and (max-width: 768px) {
            .events-shell {
                padding: 0 16px;
            }

            .events-toolbar {
                flex-direction: column;
                align-items: flex-start;
            }

            .events-heading .level-right {
                width: 100%;
                justify-content: flex-start;
            }

            .event-card .title.is-5 {
                max-width: 100%;
            }

            .events-modal-box {
                padding: 24px 20px;
            }

            #modal-formulario-evento .modal-content {
                width: min(96vw, 96vw);
            }
        }
    </style>
</head>
<body>
    <section class="section">
        <div class="container events-shell">
            <div class="events-toolbar">
                <a href="/admin" class="events-return">&larr; Regresar</a>
            </div>

            <div class="level events-heading">
                <div class="level-left">
                    <div class="level-item">
                        <div class="events-copy">
                            <h1 class="title">Catalogo de Eventos</h1>
                            <p class="subtitle is-6 has-text-grey">
                                Gestiona eventos activos e inactivos, modifica sus datos y elimina solo cuando sea necesario.
                            </p>
                        </div>
                    </div>
                </div>

                <div class="level-right">
                    <div class="level-item">
                        <div id="loading-spinner" class="button is-loading is-ghost is-hidden"></div>
                    </div>
                    <div class="level-item">
                        <button class="button is-primary is-rounded" id="btn-registrar-evento" onclick="abrirFormularioRegistro()">
                            <span>Nuevo Evento</span>
                        </button>
                    </div>
                </div>
            </div>

            <div id="feedback-eventos" class="notification is-hidden"></div>
            <div id="contenedor-eventos" class="columns is-multiline"></div>
        </div>
    </section>

    <div class="modal" id="modal-formulario-evento">
        <div class="modal-background" onclick="cerrarModalFormulario()"></div>
        <div class="modal-content">
            <div class="box events-modal-box">
                <div class="is-flex is-justify-content-space-between is-align-items-center mb-4">
                    <h3 class="title is-4 mb-0" id="titulo-form-evento">Registrar Nuevo Evento</h3>
                    <span class="tag is-light" id="modo-form-evento">Alta</span>
                </div>

                <form id="form-evento">
                    <div class="field">
                        <label class="label">Nombre del Evento</label>
                        <div class="control">
                            <input class="input" type="text" id="nombre" placeholder="Ej. Noche de Crepas">
                        </div>
                    </div>

                    <div class="field">
                        <label class="label">Descripcion</label>
                        <div class="control">
                            <input class="input" type="text" id="descripcion" placeholder="Ej. Evento especial con promociones y productos exclusivos.">
                        </div>
                    </div>

                    <div class="columns">
                        <div class="column">
                            <div class="field">
                                <label class="label">Fecha Inicio</label>
                                <div class="control">
                                    <input class="input" type="date" id="fechaInicio">
                                </div>
                            </div>
                        </div>
                        <div class="column">
                            <div class="field">
                                <label class="label">Fecha Fin</label>
                                <div class="control">
                                    <input class="input" type="date" id="fechaFin">
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="field">
                        <label class="label">Promociones (seleccion multiple)</label>
                        <div class="control">
                            <div class="select is-multiple is-fullwidth">
                                <select id="promociones" multiple size="4"></select>
                            </div>
                        </div>
                    </div>

                    <div class="field">
                        <label class="label">Productos relacionados</label>
                        <div class="control">
                            <div class="select is-multiple is-fullwidth">
                                <select id="productos" multiple size="5"></select>
                            </div>
                        </div>
                    </div>

                    <div class="field is-grouped is-grouped-right">
                        <p class="control">
                            <button type="button" class="button is-light" onclick="cerrarModalFormulario()">Cancelar</button>
                        </p>
                        <p class="control">
                            <button type="button" class="button is-primary" id="btn-guardar-evento" onclick="guardarEvento()">Guardar Evento</button>
                        </p>
                    </div>
                </form>
            </div>
        </div>
        <button class="modal-close is-large" aria-label="close" onclick="cerrarModalFormulario()"></button>
    </div>

    <div class="modal" id="modal-accion-evento">
        <div class="modal-background" onclick="cerrarModalAccionEvento()"></div>
        <div class="modal-content">
            <div class="box events-modal-box">
                <h3 class="title is-4">Estado o Eliminacion del Evento</h3>
                <p class="mb-2">
                    Evento seleccionado:
                    <strong id="nombre-evento-accion"></strong>
                </p>
                <p class="mb-4">
                    Estado actual:
                    <span class="tag" id="tag-estado-evento"></span>
                </p>

                <div class="buttons is-right">
                    <button type="button" class="button is-light" onclick="cerrarModalAccionEvento()">Cancelar</button>
                    <button type="button" class="button is-warning" id="btn-opcion-estado-evento">Cambiar estado</button>
                    <button type="button" class="button is-danger" id="btn-opcion-eliminar">Eliminar</button>
                </div>
            </div>
        </div>
        <button class="modal-close is-large" aria-label="close" onclick="cerrarModalAccionEvento()"></button>
    </div>

    <div class="modal" id="modal-confirmacion-evento">
        <div class="modal-background" onclick="volverAOpcionesEvento()"></div>
        <div class="modal-content">
            <div class="box events-modal-box">
                <h3 class="title is-4" id="titulo-confirmacion-evento">Confirmar accion</h3>
                <p id="texto-confirmacion-evento" class="mb-4"></p>

                <div class="buttons is-right">
                    <button type="button" class="button is-light" onclick="volverAOpcionesEvento()">Cancelar</button>
                    <button type="button" class="button is-warning" id="btn-confirmar-accion-evento">Confirmar</button>
                </div>
            </div>
        </div>
        <button class="modal-close is-large" aria-label="close" onclick="volverAOpcionesEvento()"></button>
    </div>

    <script src="/js/promos_eventos/eventos.js"></script>
</body>
</html>
