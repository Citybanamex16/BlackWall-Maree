<%- include('../partials/header_admin', { pageTitle: 'Detalle del Colaborador - Marée' }) %>
<%- include('../partials/breadcrumbs') %>
<meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bulma@1.0.4/css/bulma.min.css">
  <link rel="preconnect" href="https://fonts.googleapis.com"> 
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;600&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/CSSglobales/global_theme.css">
  <link rel="stylesheet" href="/css/CSSglobales/global_components.css">
  <link rel="stylesheet" href="/css/CSSglobales/adminstyle.css"> 
<main class="page-wrap">
  <header style="margin-bottom: 32px;">
    <h1 class="page-title">Detalle del Colaborador</h1>
  </header>

  <% if (typeof error !== 'undefined' && error) { %>
    <div class="notification status-pill is-danger" style="border-radius: var(--radius-md); padding: 16px; width: 100%;">
      <%= error %>
    </div>
  <% } %>

  <% if (typeof colaborador !== 'undefined' && colaborador) { %>
    <div class="card-base" style="max-width: 600px;">
      
      <div style="display: flex; flex-direction: column; gap: 16px; margin-bottom: 28px;">
        <div>
            <p style="color: var(--c-text-muted); text-transform: uppercase; font-size: 11px; letter-spacing: 1px;">ID Colaborador</p>
            <p style="font-size: 18px; font-family: var(--font-body);"><%= colaborador.id_colaborador %></p>
        </div>
        <div>
            <p style="color: var(--c-text-muted); text-transform: uppercase; font-size: 11px; letter-spacing: 1px;">Nombre Completo</p>
            <p style="font-size: 22px; font-weight: 500; color: var(--c-primary-deep);"><%= colaborador.nombre %></p>
        </div>
        <div>
            <p style="color: var(--c-text-muted); text-transform: uppercase; font-size: 11px; letter-spacing: 1px;">Rol Asignado</p>
            <span class="status-pill is-active" style="margin-top: 4px;"><%= colaborador.rol %></span>
        </div>
      </div>

      <div style="display: flex; gap: 12px; border-top: 1px solid var(--c-border); padding-top: 24px;">
        <button class="btn-danger btn-baja" data-id="<%= colaborador.id_colaborador %>" data-nombre="<%= colaborador.nombre %>">
          Dar de baja al colaborador
        </button>
        <a href="/admin/colaboradores" class="btn-ghost">Volver a la lista</a>
      </div>

    </div>
  <% } %>
</main>

<script src="/js/admin.js"></script>
</body>
</html>