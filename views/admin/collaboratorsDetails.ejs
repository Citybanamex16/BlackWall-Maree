<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Detalle del Colaborador - Marée</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bulma@1.0.4/css/bulma.min.css">
  <link rel="stylesheet" href="/css/adminstyle.css">
</head>
<body>

<nav class="navbar" role="navigation">
  <div class="navbar-brand">
    <span class="navbar-item logo">MARÉE</span>
  </div>
</nav>

<section class="section">
  <div class="container">
    <h1 class="title">Detalle del colaborador</h1>

    <% if (error) { %>
      <div class="notification is-danger"><%= error %></div>
    <% } %>

    <% if (colaborador) { %>
      <div class="box">
        <p><strong>ID:</strong> <%= colaborador.id_colaborador %></p>
        <p><strong>Nombre:</strong> <%= colaborador.nombre %></p>
        <p><strong>Rol:</strong> <%= colaborador.rol %></p>

        <div class="mt-4">
          <button
            class="button is-danger btn-baja"
            data-id="<%= colaborador.id_colaborador %>"
            data-nombre="<%= colaborador.nombre %>">
            Dar de baja
          </button>

          <a href="/admin/colaboradores" class="button is-light">Volver</a>
        </div>
      </div>
    <% } %>
  </div>
</section>

<script src="/js/admin.js"></script>
</body>
</html>