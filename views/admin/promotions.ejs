<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Promotions - Admin Marée</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bulma@1.0.4/css/bulma.min.css">
    <link rel="stylesheet" href="/css/adminstyle.css">
</head>
<body>
    <section class="section">
        <div class="container">
            <h1 class="title">Catálogo de Promociones</h1>
            <p class="subtitle">Aquí va el catálogo de promociones</p>
        </div>
        
    </section>
    <section class = "section">
        <div class = "container">
            <div class = "level">
                <div class = "level-left">
                    <div class = "level-item">
                        <h1 class = "title"> Gestión de Promociones</h1>
                    </div>
                </div>
            </div>
        </div>
        <div class="level-right">
            <div class="level-item">
                <div class="button is-primary is-rounded">
                    <a href = "admin/promociones">
                        <button class="button is-primary">Nueva promoción</button>
                    </a>
                </div>
            </div> 
        </div> 
    </section>
    <div class="modal" id ="modal-evento">
        <div class="modal-background"></div>
        <div class="modal-content">
            <div class="box">
                <h3 class="title is-4"> Registrar Nueva Promoción </h3>
                <form id="form-evento">
                    <div class="field">
                        <label class="label">Nombre</label>
                        <div class="control">
                            <input class="input" type="text" placeholder="Ex. Crepas a mitad de precio">
                        </div>
                    </div>
                    <div class="field">
                        <label class="label">Descuento</label>
                        <div class="control">
                            <input class="input" type="text" placeholder=".50">
                        </div>
                    </div>
                    <div class="field">
                        <label class="label">Condiciones</label>
                        <div class="control">
                            <input class="input" type="text" placeholder="Es necesario comprar una crepa...">
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
    <script></script>

</body>
</html>