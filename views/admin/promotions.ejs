<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Promotions - Admin Marée</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bulma@1.0.4/css/bulma.min.css">
    <link rel="stylesheet" href="/css/adminstyle.css">
</head>
<body>
    <section class="section">
        <div class="container">
            <h1 class="title">Catálogo de Promociones</h1>
            <p class="subtitle">Aquí va el catálogo de promociones</p>
        </div>
        
    </section>
    <section class = "section">
        <div class = "container">
            <div class = "level">
                <div class = "level-left">
                    <div class = "level-item">
                        <h1 class = "title"> Gestión de Promociones</h1>
                    </div>
                </div>
            </div>
        </div>
        <div class="level-right">
            <div class="level-item">
                <div class="button is-primary is-rounded">
                    <!-- Agregar la funcionalidad de abrirModal-->
                        <button class="button is-primary" onclick="abrirModal()">Nueva promoción</button>
                </div>
            </div> 
        </div> 
    </section>
    <!-- Pop up de registrar una promocion-->
    <div class="modal" id ="modal-promocion">
        <div class="modal-background"></div>
        <div class="modal-content">
            <div class="box">
                <h3 class="title is-4"> Registrar Nueva Promoción </h3>
                <form id="form-promocion">
                    <div class="field">
                        <label class="label">Nombre</label>
                        <div class="control">
                            <input id = "nombre" class="input" type="text" placeholder="Ex. Crepas a mitad de precio">
                        </div>
                    </div>
                    <div class = "field">
                        <label class="checkbox">
                        <input type="checkbox" id = "check-descuento" onclick="nuevoDescuento()"/>¿Descuento?
                    </label>
                    </div>
                    <div class="field" id="seccion-descuento" style="display: none;">
                        <label class="label" >Descuento</label>
                        <div class="control">
                            <input class="input" id="descuento" type="number" placeholder="50">
                        </div>
                    </div>
                    <div class="field">
                        <label class="label">Condiciones</label>
                        <div class="control">
                            <input class="input" type="text" 
                            id = "condiciones" placeholder="Es necesario comprar una crepa...">
                        </div>
                    </div>
                    <div class="field">
                        <label class="label">Fecha de Inicio</label>
                        <div class="control">
                            <input class="input" id= "fecha_de_Inicio" type="date">
                        </div>
                    </div>
                    <div class="field">
                        <label class="label">Fecha de Fin</label>
                        <div class="control">
                            <input class="input" type="date" id= "fecha_de_Fin">
                        </div>
                    </div>
                    <div class="buttons">
                        <button type = "button" class="button is-primary" 
                        onclick="guardarPromocion()">Guardar</button>
                        <button type="button" class="button" 
                        onclick="cerrarModal()"> Cancelar</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
    <script src = "/js/promos_eventos/promociones.js"></script>

</body>
</html>