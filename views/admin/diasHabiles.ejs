<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= pageTitle %> - Marée</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bulma@1.0.4/css/bulma.min.css">
  <link rel="stylesheet" href="/css/adminstyle.css">
</head>
<body>

<nav class="navbar" role="navigation">
  <div class="navbar-brand">
    <span class="navbar-item logo">MARÉE</span>
  </div>
</nav>

<section class="section">
  <div class="container">
    <h1 class="title">Gestión de días hábiles</h1>
    <p class="subtitle">Consulta de días hábiles y horarios de atención</p>

    <% if (error) { %>
      <div class="notification is-danger"><%= error %></div>
    <% } %>

    <% if (mensaje) { %>
      <div class="notification is-warning"><%= mensaje %></div>
      <div class="mt-4">
        <a href="/admin" class="button is-light">Volver al dashboard</a>
      </div>
    <% } %>

    <% if (diasHabiles && diasHabiles.length > 0) { %>
      <div class="box">
        <table class="table is-fullwidth is-striped is-hoverable">
          <thead>
            <tr>
              <th>ID</th>
              <th>Sucursal</th>
              <th>Fecha</th>
              <th>Laboral</th>
              <th>Descripción</th>
            </tr>
          </thead>
          <tbody>
            <% diasHabiles.forEach(dia => { %>
              <tr>
                <td><%= dia.id_calendario %></td>
                <td><%= dia.nombre_sucursal || dia.id_sucursal %></td>
                <td><%= dia.fecha ? String(dia.fecha).slice(0, 10) : '' %></td>
                <td><%= dia.es_laboral ? 'Sí' : 'No' %></td>
                <td><%= dia.descripcion || '' %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>

      <a href="/admin" class="button is-light">Volver al dashboard</a>
    <% } %>
  </div>
</section>

</body>
</html>