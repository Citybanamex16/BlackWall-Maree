<!DOCTYPE html>
<html lang="es" data-theme="light">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Órdenes</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bulma@1.0.4/css/bulma.min.css">
  <link rel="stylesheet" href="/css/CSSglobales/global_theme.css">
  <link rel="stylesheet" href="/css/CSSglobales/global_components.css">
  <link rel="stylesheet" href="/css/CSSglobales/module-dashboard.css">
  <link rel="stylesheet" href="/css/moduloMenuCSS/moduloMenuAdminCSS.css">
  <link rel="stylesheet" href="/css/moduloAdminCSS/moduloAdmincss.css">
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400&family=Jost:wght@300;400;500&display=swap" rel="stylesheet">
</head>

<body>
  <nav class="navbar">
    <div class="navbar-brand">
      <div class="navbar-item" style="display:flex; flex-direction:column; align-items:flex-start;">
        <div class="logo-text">MARÉE</div>
        <div class="logo-sub">Admin</div>
      </div>
    </div>
    <div class="navbar-end" style="display:flex;">
      <a href="/admin" class="navbar-item">Dashboard</a>
      <a href="/admin/ordenes" class="navbar-item" style="color: var(--gold);">Órdenes</a>
    </div>
  </nav>

  <section class="section">
    <div class="container">
      <h1 class="title">Catálogo de Órdenes</h1>
      <p class="subtitle">órdenes registradas y cancelar las que sigan activas.</p>

    <div id="statusBox" class="status-box"></div>

    <div class="container">
      <% if (error) { %>
        <article class="message is-danger">
          <div class="message-body">
            <%= error %>
          </div>
        </article>
      <% } %>

      <div id="alert-container"></div>

      <div class="table-container">
        <table class="table is-fullwidth is-hoverable is-striped">
          <thead>
            <tr>
              <th>ID Orden</th>
              <th>Cliente</th>
              <th>Teléfono</th>
              <th>Tipo</th>
              <th>Estatus</th>
              <th>Fecha</th>
              <th>Acciones</th>
            </tr>
          </thead>
          <tbody>
            <% if (pedidos && pedidos.length > 0) { %>
              <% pedidos.forEach((pedido) => { %>
                <tr data-order-row="<%= pedido.id_orden %>">
                  <td><%= pedido.id_orden %></td>
                  <td><%= pedido.nombre_cliente || 'Sin nombre' %></td>
                  <td><%= pedido.telefono || 'Sin teléfono' %></td>
                  <td><%= pedido.tipo_orden || 'Sin tipo' %></td>
                  <td class="order-status-cell">
                    <span class="tag is-light order-status-text"><%= pedido.estado_orden %></span>
                  </td>
                  <td><%= pedido.fecha || 'Sin fecha' %></td>
                  <td class="order-actions">
                    <% if (pedido.estado_orden !== 'Cancelado' && pedido.estado_orden !== 'Entregado') { %>
                      <button
                        class="button is-danger is-light btn-cancel-order"
                        data-order-id="<%= pedido.id_orden %>">
                        Cancelar pedido
                      </button>
                    <% } else { %>
                      <span class="tag is-light">No disponible</span>
                    <% } %>
                  </td>
                </tr>
              <% }) %>
            <% } else { %>
              <tr>
                <td colspan="7" class="has-text-centered">No hay órdenes registradas.</td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <div class="modal" id="cancel-order-modal">
    <div class="modal-background"></div>
    <div class="modal-card">
      <header class="modal-card-head">
        <p class="modal-card-title">Cancelar pedido</p>
        <button class="delete" aria-label="close" id="close-cancel-modal"></button>
      </header>
      <section class="modal-card-body">
        <p>¿Seguro que deseas cancelar esta orden?</p>
      </section>
      <footer class="modal-card-foot">
        <button class="button" id="cancel-modal-btn">Volver</button>
        <button class="button is-danger" id="confirm-cancel-btn">Sí, cancelar</button>
      </footer>
    </div>
  </div>

  <script src="/js/orders-cancel.js"></script>
</body>
</html>